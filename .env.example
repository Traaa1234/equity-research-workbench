# Neon Postgres — two connection strings for two roles.
# DATABASE_URL: the role used by user-scoped routes (subject to RLS).
# DATABASE_URL_SERVICE_ROLE: the role used by cron and ingestion (BYPASSRLS).
# In Neon dashboard: create your project → Connection Details → copy the
# connection string. For the service role, create a second role with
# `BYPASSRLS` and copy its connection string.
DATABASE_URL=
DATABASE_URL_SERVICE_ROLE=

# Stack Auth (https://stack-auth.com)
# Console → your project → API Keys → copy all three.
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# Financial Datasets API
# Get a free-tier key at https://financialdatasets.ai
FINANCIAL_DATASETS_API_KEY=

# Upstash Redis (free tier)
# Console → Redis database → REST API tab → copy URL and token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron handler shared secret (32 hex chars recommended)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
CRON_SECRET=

# Python interpreter used by yfinance adapter (override if not on PATH)
PYTHON_BIN=python
